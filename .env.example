# ReverseLab Environment Variables
# Copy to .env and fill in your values

# GitHub Personal Access Token (for GitHub MCP server)
GITHUB_PERSONAL_ACCESS_TOKEN=

# JSHook Configuration (optional)
JSHOOK_OPENAI_API_KEY=
JSHOOK_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
JSHOOK_MODE=external-controller
