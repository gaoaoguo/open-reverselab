# Environment secrets
.env
.env.*
!.env.example
SECURITY.md

# Python / Node caches
__pycache__/
*.pyc
node_modules/

# Logs
logs/*.log

# ── Tools: ignore binaries, keep README.md + .gitkeep ──
tools/common/**
!tools/common/**/
!tools/common/**/README.md
!tools/common/**/.gitkeep
tools/windows/**
!tools/windows/**/
!tools/windows/**/README.md
!tools/windows/**/.gitkeep
tools/android/**
!tools/android/**/
!tools/android/**/README.md
!tools/android/**/.gitkeep

