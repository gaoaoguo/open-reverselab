tools/ctf-website/sqlmap/
tools/ctf-website/dirsearch/
tools/ctf-website/jwt_tool/
tools/ctf-website/tplmap/
tools/ctf-website/nmap/
tools/ctf-website/exploitdb/
tools/ctf-website/burp/
tools/ctf-website/browser/

# ── Content dirs: ignore binaries, keep README.md + .gitkeep ──
projects/**
!projects/**/
!projects/**/README.md
!projects/**/.gitkeep
samples/**
!samples/**/
!samples/**/README.md
!samples/**/.gitkeep
patches/**
!patches/**/
!patches/**/README.md
!patches/**/.gitkeep
exports/**
!exports/**/
!exports/**/README.md
!exports/**/.gitkeep

# Ghidra / Cutter / x64dbg project files
*.rep/
*.gpr
*.db
*.sqlite

